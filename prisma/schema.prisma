generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & RBAC Enums ──────────────────────────────────────────────────────

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  USER
  PLAYER
}

enum TournamentRole {
  TOURNAMENT_OWNER
  TOURNAMENT_ADMIN
  TEAM_MANAGER
  AUCTIONEER
  SCORER
  VIEWER
}

// ─── Domain Enums ────────────────────────────────────────────────────────────

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  AUCTION_SCHEDULED
  AUCTION_IN_PROGRESS
  AUCTION_COMPLETED
  SCHEDULE_READY
  LIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum TournamentFormat {
  T10
  T20
  ODI
  TEST
  HUNDRED
}

enum RegistrationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WAITLISTED
  WITHDRAWN
}

enum PlayerRole {
  BATTER
  BOWLER
  ALL_ROUNDER
  WICKET_KEEPER
}

enum BowlingStyle {
  RIGHT_ARM_FAST
  RIGHT_ARM_MEDIUM
  RIGHT_ARM_MEDIUM_FAST
  LEFT_ARM_FAST
  LEFT_ARM_MEDIUM
  LEFT_ARM_MEDIUM_FAST
  RIGHT_ARM_OFF_SPIN
  LEFT_ARM_ORTHODOX
  RIGHT_ARM_LEG_SPIN
  LEFT_ARM_WRIST_SPIN
  SLOW_LEFT_ARM_ORTHODOX
  SLOW_RIGHT_ARM_OFF_SPIN
  DOES_NOT_BOWL
}

enum BattingStyle {
  RIGHT_HAND
  LEFT_HAND
}

enum AuctionSeriesStatus {
  PLANNED
  LIVE
  PAUSED
  CLOSED
}

enum AuctionRoundType {
  MARQUEE
  CAPPED
  UNCAPPED
  EMERGING
  OVERSEAS
  ACCELERATED
}

enum TeamStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  WITHDRAWN
}

enum PlayerAcquisitionType {
  AUCTION
  DRAFT
  RETAINED
  REPLACEMENT
}

enum MatchStage {
  GROUP_STAGE
  LEAGUE
  SUPER_FOUR
  QUALIFIER_1
  QUALIFIER_2
  ELIMINATOR
  PLAYOFF
  SEMI_FINAL
  FINAL
}

enum MatchStatus {
  SCHEDULED
  TOSS_PENDING
  LIVE
  INNINGS_BREAK
  COMPLETED
  ABANDONED
  NO_RESULT
  CANCELLED
}

enum MatchResultType {
  TEAM_WIN
  TIE
  NO_RESULT
  ABANDONED
}

enum TossDecision {
  BAT
  BOWL
}

enum PointsTableEntryType {
  WIN
  LOSS
  TIE
  NO_RESULT
  BONUS
}

enum InningsStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DECLARED
}

enum DismissalType {
  BOWLED
  CAUGHT
  LBW
  RUN_OUT
  STUMPED
  HIT_WICKET
  RETIRED_HURT
  RETIRED_OUT
  OBSTRUCTING_FIELD
  TIMED_OUT
  HANDLED_BALL
  MANKAD
  HIT_THE_BALL_TWICE
}

enum ExtraType {
  WIDE
  NO_BALL
  BYE
  LEG_BYE
  PENALTY
}

enum NotificationType {
  REGISTRATION_SUBMITTED
  REGISTRATION_APPROVED
  REGISTRATION_REJECTED
  AUCTION_STARTED
  AUCTION_PLAYER_SOLD
  MATCH_SCHEDULED
  MATCH_STARTED
  MATCH_COMPLETED
  TEAM_CREATED
  GENERAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  BOTH
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  firstName       String
  lastName        String?
  displayName     String
  phone           String?
  avatarUrl       String?
  systemRole      SystemRole @default(USER)
  emailVerified   Boolean    @default(false)
  emailVerifiedAt DateTime?
  isActive        Boolean    @default(true)
  lastLoginAt     DateTime?
  lastLoginIp     String?
  loginCount      Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  sessions           Session[]
  tournamentAccesses UserTournamentAccess[]
  linkedPlayer       Player?
  notifications      Notification[]

  @@index([email])
  @@index([systemRole, isActive])
}

/// Fine-grained keys (e.g. admin.users.read) assigned per SystemRole — editable from the dashboard.
model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  createdAt   DateTime @default(now())

  roleGrants SystemRolePermission[]
}

model SystemRolePermission {
  id           String     @id @default(cuid())
  systemRole   SystemRole
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([systemRole, permissionId])
  @@index([systemRole])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model UserTournamentAccess {
  id           String         @id @default(cuid())
  userId       String
  tournamentId String
  role         TournamentRole
  teamId       String?
  grantedBy    String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId, role])
  @@index([userId, isActive])
  @@index([tournamentId, isActive])
}

// ─── Tournament ──────────────────────────────────────────────────────────────

model Tournament {
  id                String           @id @default(cuid())
  code              String           @unique
  name              String
  shortName         String?
  description       String?
  logoUrl           String?
  bannerUrl         String?
  season            Int
  format            TournamentFormat @default(T20)
  status            TournamentStatus @default(DRAFT)
  organizerName     String?
  organizerEmail    String?
  organizerPhone    String?
  venueCity         String?
  country           String?
  timezone          String           @default("Asia/Kolkata")
  registrationOpen  DateTime?
  registrationClose DateTime?
  auctionStartDate  DateTime?
  startsOn          DateTime?
  endsOn            DateTime?
  maxTeams          Int              @default(8)
  minSquadSize      Int              @default(15)
  maxSquadSize      Int              @default(25)
  overseasLimit     Int              @default(4)
  retentionLimit    Int              @default(5)
  pursePerTeam      Decimal          @db.Decimal(14, 2)
  matchOvers        Decimal          @default(20) @db.Decimal(5, 1)
  powerplayOvers    Decimal          @default(6) @db.Decimal(5, 1)
  pointsForWin      Decimal          @default(2) @db.Decimal(5, 2)
  pointsForTie      Decimal          @default(1) @db.Decimal(5, 2)
  pointsForNR       Decimal          @default(1) @db.Decimal(5, 2)
  nrrEnabled        Boolean          @default(true)
  isPublic          Boolean          @default(false)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  teams               Team[]
  matches             Match[]
  auctionSeries       AuctionSeries[]
  playerRegistrations TournamentPlayerRegistration[]
  auctionBids         AuctionBid[]
  teamPurseLedgers    TeamPurseLedger[]
  teamSquadPlayers    TeamSquadPlayer[]
  pointsTable         PointsTableEntry[]
  userAccesses        UserTournamentAccess[]
  settings            TournamentSettings?
  notifications       Notification[]

  @@unique([name, season])
  @@index([status])
  @@index([season])
  @@index([isPublic, status])
}

// ─── Team ────────────────────────────────────────────────────────────────────

model Team {
  id             String     @id @default(cuid())
  tournamentId   String
  code           String
  name           String
  shortName      String?
  ownerName      String?
  managerName    String?
  coachName      String?
  captainName    String?
  city           String?
  homeGround     String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  status         TeamStatus @default(ACTIVE)
  purseTotal     Decimal    @db.Decimal(14, 2)
  purseSpent     Decimal    @default(0) @db.Decimal(14, 2)
  purseRemaining Decimal    @default(0) @db.Decimal(14, 2)
  retainedCount  Int        @default(0)
  squadMin       Int        @default(15)
  squadMax       Int        @default(25)
  overseasMin    Int        @default(0)
  overseasMax    Int        @default(4)
  contactEmail   String?
  contactPhone   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  purseLedgers  TeamPurseLedger[]
  squadPlayers  TeamSquadPlayer[]
  auctionBids   AuctionBid[]
  matchesAsHome Match[]            @relation("HomeTeam")
  matchesAsAway Match[]            @relation("AwayTeam")
  matchesWon    Match[]            @relation("WinningTeam")
  pointsEntries PointsTableEntry[]
  playingXI     MatchPlayingXI[]

  @@unique([tournamentId, code])
  @@unique([tournamentId, name])
  @@index([tournamentId, status])
}

// ─── Player ──────────────────────────────────────────────────────────────────

model Player {
  id               String        @id @default(cuid())
  userId           String?       @unique
  code             String?       @unique
  firstName        String
  lastName         String?
  displayName      String
  dateOfBirth      DateTime?
  age              Int?
  gender           String?
  nationality      String?
  state            String?
  city             String?
  role             PlayerRole
  battingStyle     BattingStyle?
  bowlingStyle     BowlingStyle?
  isOverseas       Boolean       @default(false)
  isWicketKeeper   Boolean       @default(false)
  isCapped         Boolean       @default(false)
  t20Matches       Int           @default(0)
  odiMatches       Int           @default(0)
  testMatches      Int           @default(0)
  battingRating    Int           @default(0)
  bowlingRating    Int           @default(0)
  fieldingRating   Int           @default(0)
  allRounderRating Int           @default(0)
  reservePrice     Decimal?      @db.Decimal(14, 2)
  basePrice        Decimal?      @db.Decimal(14, 2)
  profilePhotoUrl  String?
  bio              String?
  email            String?
  phone            String?
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user           User?                          @relation(fields: [userId], references: [id], onDelete: SetNull)
  registrations  TournamentPlayerRegistration[]
  auctionBids    AuctionBid[]
  squadEntries   TeamSquadPlayer[]
  playingXI      MatchPlayingXI[]
  ballsAsBatsman BallByBall[]                   @relation("BallBatsman")
  ballsAsBowler  BallByBall[]                   @relation("BallBowler")

  @@index([displayName])
  @@index([role])
  @@index([nationality])
  @@index([isCapped])
}

// ─── Tournament Player Registration ──────────────────────────────────────────

model TournamentPlayerRegistration {
  id                 String             @id @default(cuid())
  tournamentId       String
  playerId           String
  status             RegistrationStatus @default(SUBMITTED)
  registrationNumber String
  jerseyName         String?
  jerseyNumber       Int?
  preferredRole      PlayerRole?
  expectedPrice      Decimal?           @db.Decimal(14, 2)
  fitnessCleared     Boolean            @default(false)
  documentsVerified  Boolean            @default(false)
  medicalCleared     Boolean            @default(false)
  approvedBy         String?
  approvedAt         DateTime?
  rejectedBy         String?
  rejectedAt         DateTime?
  rejectionReason    String?
  reviewNotes        String?
  finalShortlistRank Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id])

  @@unique([tournamentId, playerId])
  @@unique([tournamentId, registrationNumber])
  @@index([tournamentId, status])
  @@index([playerId])
}

// ─── Auction System ──────────────────────────────────────────────────────────

model AuctionSeries {
  id                String              @id @default(cuid())
  tournamentId      String
  name              String
  sequenceNo        Int
  status            AuctionSeriesStatus @default(PLANNED)
  startsAt          DateTime?
  endsAt            DateTime?
  minBidIncrement   Decimal             @default(10) @db.Decimal(14, 2)
  defaultBidTimeSec Int                 @default(30)
  maxBidTimeSec     Int                 @default(120)
  totalPlayersSold  Int                 @default(0)
  totalAmountSpent  Decimal             @default(0) @db.Decimal(14, 2)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tournament Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rounds     AuctionRound[]
  bids       AuctionBid[]

  @@unique([tournamentId, sequenceNo])
  @@index([tournamentId, status])
}

model AuctionRound {
  id              String           @id @default(cuid())
  auctionSeriesId String
  roundNo         Int
  name            String
  type            AuctionRoundType
  maxPlayers      Int?
  nominationOrder Json?
  startsAt        DateTime?
  endsAt          DateTime?
  playersSold     Int              @default(0)
  amountSpent     Decimal          @default(0) @db.Decimal(14, 2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  auctionSeries AuctionSeries @relation(fields: [auctionSeriesId], references: [id])
  bids          AuctionBid[]

  @@unique([auctionSeriesId, roundNo])
  @@index([auctionSeriesId, type])
}

model AuctionBid {
  id              String   @id @default(cuid())
  auctionSeriesId String
  auctionRoundId  String?
  tournamentId    String
  teamId          String
  playerId        String
  bidAmount       Decimal  @db.Decimal(14, 2)
  isWinningBid    Boolean  @default(false)
  isAutoBid       Boolean  @default(false)
  bidAt           DateTime @default(now())
  paddleNumber    String?
  remarks         String?

  auctionSeries AuctionSeries @relation(fields: [auctionSeriesId], references: [id])
  auctionRound  AuctionRound? @relation(fields: [auctionRoundId], references: [id])
  team          Team          @relation(fields: [teamId], references: [id])
  player        Player        @relation(fields: [playerId], references: [id])
  tournament    Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([auctionSeriesId, playerId, bidAt])
  @@index([teamId, bidAt])
  @@index([tournamentId, isWinningBid])
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum LedgerTransactionType {
  INITIAL_ALLOCATION
  AUCTION_PURCHASE
  RETENTION_DEDUCTION
  RELEASE_REFUND
  PENALTY
  BONUS
  ADJUSTMENT
}

// ─── Team Finance & Squad ────────────────────────────────────────────────────

model TeamPurseLedger {
  id              String                @id @default(cuid())
  teamId          String
  tournamentId    String
  amount          Decimal               @db.Decimal(14, 2)
  direction       LedgerDirection
  transactionType LedgerTransactionType
  referenceType   String?
  referenceId     String?
  balanceAfter    Decimal?              @db.Decimal(14, 2)
  remarks         String?
  createdAt       DateTime              @default(now())

  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@index([tournamentId, createdAt])
}

model TeamSquadPlayer {
  id                String                @id @default(cuid())
  tournamentId      String
  teamId            String
  playerId          String
  acquisitionType   PlayerAcquisitionType
  acquisitionAmount Decimal?              @db.Decimal(14, 2)
  jerseyNumber      Int?
  isCaptain         Boolean               @default(false)
  isViceCaptain     Boolean               @default(false)
  isOverseas        Boolean               @default(false)
  isActive          Boolean               @default(true)
  joinedAt          DateTime              @default(now())
  releasedAt        DateTime?
  releaseReason     String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id])

  @@unique([tournamentId, playerId])
  @@index([teamId, isActive])
  @@index([tournamentId, teamId])
}

// ─── Match ───────────────────────────────────────────────────────────────────

model Match {
  id               String           @id @default(cuid())
  tournamentId     String
  matchNo          Int
  stage            MatchStage       @default(LEAGUE)
  groupName        String?
  homeTeamId       String
  awayTeamId       String
  venueName        String?
  city             String?
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  tossWonByTeamId  String?
  tossDecision     TossDecision?
  status           MatchStatus      @default(SCHEDULED)
  winningTeamId    String?
  resultType       MatchResultType?
  resultSummary    String?
  winMarginRuns    Int?
  winMarginWickets Int?
  pointsHome       Decimal?         @db.Decimal(5, 2)
  pointsAway       Decimal?         @db.Decimal(5, 2)
  oversPerSide     Decimal          @default(20) @db.Decimal(5, 1)
  umpire1          String?
  umpire2          String?
  thirdUmpire      String?
  referee          String?
  highlights       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tournament  Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam    Team             @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team             @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winningTeam Team?            @relation("WinningTeam", fields: [winningTeamId], references: [id])
  innings     Innings[]
  playingXI   MatchPlayingXI[]

  @@unique([tournamentId, matchNo])
  @@index([tournamentId, status, scheduledAt])
  @@index([tournamentId, stage])
}

// ─── Points Table ────────────────────────────────────────────────────────────

model PointsTableEntry {
  id           String   @id @default(cuid())
  tournamentId String
  teamId       String
  played       Int      @default(0)
  won          Int      @default(0)
  lost         Int      @default(0)
  tied         Int      @default(0)
  noResult     Int      @default(0)
  points       Decimal  @default(0) @db.Decimal(7, 2)
  nrr          Decimal  @default(0) @db.Decimal(7, 4)
  runsScored   Int      @default(0)
  oversFaced   Decimal  @default(0) @db.Decimal(7, 1)
  runsConceded Int      @default(0)
  oversBowled  Decimal  @default(0) @db.Decimal(7, 1)
  position     Int      @default(0)
  groupName    String?
  lastUpdated  DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([tournamentId, points, nrr])
  @@index([tournamentId, position])
}

// ─── Innings & Ball-by-Ball ──────────────────────────────────────────────────

model Innings {
  id            String        @id @default(cuid())
  matchId       String
  inningsNo     Int
  battingTeamId String
  bowlingTeamId String
  status        InningsStatus @default(NOT_STARTED)
  totalRuns     Int           @default(0)
  totalWickets  Int           @default(0)
  totalOvers    Decimal       @default(0) @db.Decimal(5, 1)
  totalBalls    Int           @default(0)
  extras        Int           @default(0)
  wides         Int           @default(0)
  noBalls       Int           @default(0)
  byes          Int           @default(0)
  legByes       Int           @default(0)
  penalties     Int           @default(0)
  runRate       Decimal       @default(0) @db.Decimal(5, 2)
  targetScore   Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  match      Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  balls      BallByBall[]
  commentary Commentary[]

  @@unique([matchId, inningsNo])
  @@index([matchId])
}

model BallByBall {
  id            String         @id @default(cuid())
  inningsId     String
  overNo        Int
  ballNo        Int
  batsmanId     String
  bowlerId      String
  nonStrikerId  String?
  runs          Int            @default(0)
  isExtra       Boolean        @default(false)
  extraType     ExtraType?
  extraRuns     Int            @default(0)
  totalRuns     Int            @default(0)
  isWicket      Boolean        @default(false)
  dismissalType DismissalType?
  dismissedId   String?
  fielderId     String?
  isFour        Boolean        @default(false)
  isSix         Boolean        @default(false)
  isDot         Boolean        @default(false)
  isFreeHit     Boolean        @default(false)
  ballSpeed     Decimal?       @db.Decimal(5, 1)
  shotType      String?
  createdAt     DateTime       @default(now())

  innings Innings @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  batsman Player  @relation("BallBatsman", fields: [batsmanId], references: [id])
  bowler  Player  @relation("BallBowler", fields: [bowlerId], references: [id])

  @@unique([inningsId, overNo, ballNo])
  @@index([inningsId, overNo])
  @@index([batsmanId])
  @@index([bowlerId])
  @@index([inningsId, batsmanId])
}

model Commentary {
  id          String   @id @default(cuid())
  inningsId   String
  overNo      Int
  ballNo      Int?
  text        String
  isHighlight Boolean  @default(false)
  createdAt   DateTime @default(now())

  innings Innings @relation(fields: [inningsId], references: [id], onDelete: Cascade)

  @@index([inningsId, overNo])
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id           String              @id @default(cuid())
  userId       String?
  tournamentId String?
  type         NotificationType    @default(GENERAL)
  channel      NotificationChannel @default(IN_APP)
  title        String
  message      String
  link         String?
  isRead       Boolean             @default(false)
  readAt       DateTime?
  emailSent    Boolean             @default(false)
  emailSentAt  DateTime?
  createdAt    DateTime            @default(now())

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([tournamentId, createdAt])
}

// ─── Utility Models ──────────────────────────────────────────────────────────

model EmailLog {
  id           String   @id @default(cuid())
  to           String
  subject      String
  html         String?
  text         String?
  status       String   @default("SENT")
  error        String?
  tournamentId String?
  createdAt    DateTime @default(now())
}

model Asset {
  id          String   @id @default(cuid())
  bucket      String
  key         String   @unique
  contentType String?
  size        Int?
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

// ─── Match Playing XI ────────────────────────────────────────────────────

model MatchPlayingXI {
  id             String   @id @default(cuid())
  matchId        String
  teamId         String
  playerId       String
  slotNo         Int
  role           String?
  isCaptain      Boolean  @default(false)
  isViceCaptain  Boolean  @default(false)
  isWicketKeeper Boolean  @default(false)
  createdAt      DateTime @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamId, playerId])
  @@unique([matchId, teamId, slotNo])
  @@index([matchId, teamId])
}

// ─── Tournament Settings ─────────────────────────────────────────────────

model TournamentSettings {
  id                  String   @id @default(cuid())
  tournamentId        String   @unique
  autoSchedule        Boolean  @default(false)
  allowLateReg        Boolean  @default(false)
  requireApproval     Boolean  @default(true)
  enableLiveScoring   Boolean  @default(true)
  enableCommentary    Boolean  @default(true)
  enableNotifications Boolean  @default(true)
  emailOnRegistration Boolean  @default(true)
  emailOnApproval     Boolean  @default(true)
  emailOnMatchResult  Boolean  @default(false)
  publicScoreboard    Boolean  @default(true)
  showPlayerStats     Boolean  @default(true)
  showTeamFinances    Boolean  @default(false)
  auctionBidTimeSec   Int      @default(30)
  auctionMinIncrement Decimal  @default(10) @db.Decimal(14, 2)
  matchDlsEnabled     Boolean  @default(false)
  powerplayEnd        Int      @default(6)
  middleOversEnd      Int      @default(15)
  maxOversPerBowler   Int      @default(4)
  freeHitOnNoBall     Boolean  @default(true)
  wideRunPenalty      Int      @default(1)
  noBallRunPenalty    Int      @default(1)
  customRules         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}
